# Database
OSINT_DATABASE_URL=postgresql+asyncpg://osint:osint_dev_password@localhost:5432/osint_db
OSINT_DATABASE_URL_SYNC=postgresql+psycopg://osint:osint_dev_password@localhost:5432/osint_db

# Application
OSINT_DEBUG=true
OSINT_REPORTS_DIR=./reports
OSINT_SECRET_KEY=change-me-in-production

# HTTP Client
OSINT_HTTP_TIMEOUT=30
OSINT_HTTP_MAX_RETRIES=3
OSINT_HTTP_RATE_LIMIT_PER_SECOND=2.0

# Optional API Keys
# OSINT_HIBP_API_KEY=
# OSINT_SHODAN_API_KEY=
# OSINT_VIRUSTOTAL_API_KEY=
# OSINT_ABUSEIPDB_API_KEY=

# Web Interface
OSINT_WEB_HOST=127.0.0.1
OSINT_WEB_PORT=8000
